import requests
import pandas as pd

query = """
[out:json][timeout:60];
area["ISO3166-1"="ES"][admin_level=2];
node["amenity"="recycling"]["recycling:clothes"="yes"](area);
out body;
"""

url = "https://overpass-api.de/api/interpreter"
response = requests.get(url, params={"data": query})
data = response.json()

# Преобразуем в таблицу
rows = []
for el in data["elements"]:
    rows.append({
        "id": el["id"],
        "lat": el["lat"],
        "lon": el["lon"],
        "tags": el.get("tags", {})
    })

df = pd.DataFrame(rows)
df.to_csv("textile_containers_spain.csv", index=False)
